{
  "name": "theoremts-agent",
  "version": "0.3.2",
  "description": "Programmatic verification API for AI agents — verify TypeScript code against contracts",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/theoremts/theorem"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch",
    "test": "node --test 'dist/*.test.js' 'dist/**/*.test.js'",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@theoremts/core": "0.3.2"
  },
  "devDependencies": {
    "typescript": "*",
    "@types/node": "*"
  },
  "keywords": [
    "theorem",
    "theoremts",
    "formal-verification",
    "ai",
    "agent",
    "code-validation",
    "z3"
  ]
}
