{
  "name": "theoremts-cli",
  "version": "0.2.7",
  "description": "CLI for Theorem — formal verification for TypeScript",
  "license": "MIT",
  "bin": {
    "theorem": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "keywords": [
    "formal-verification",
    "z3",
    "cli",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/theoremts/theorem"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@theoremts/core": "0.2.7",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "typescript": "*",
    "@types/node": "*"
  }
}
