{
  "name": "theoremts-plugins",
  "version": "0.2.8",
  "description": "Bundler plugins for Theorem — strip contracts at build time (vite, esbuild, tsup)",
  "license": "MIT",
  "exports": {
    "./vite": {
      "import": "./dist/vite.js",
      "require": "./dist/vite.js",
      "types": "./dist/vite.d.ts"
    },
    "./esbuild": {
      "import": "./dist/esbuild.js",
      "require": "./dist/esbuild.js",
      "types": "./dist/esbuild.d.ts"
    },
    "./tsup": {
      "import": "./dist/tsup.js",
      "require": "./dist/tsup.js",
      "types": "./dist/tsup.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/theoremts/theorem"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch",
    "test": "node --test 'dist/transform.test.js'",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "peerDependencies": {
    "esbuild": ">=0.19",
    "vite": ">=5"
  },
  "peerDependenciesMeta": {
    "esbuild": { "optional": true },
    "vite": { "optional": true }
  },
  "devDependencies": {
    "typescript": "*",
    "@types/node": "*",
    "esbuild": "^0.24.0",
    "vite": "^6.0.0"
  }
}
