{
  "name": "theoremts-ts-plugin",
  "version": "0.2.1",
  "description": "TypeScript Language Service Plugin for Theorem — inline verification in VS Code",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/theoremts/theorem"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@theoremts/core": "0.2.1"
  },
  "devDependencies": {
    "typescript": "*",
    "@types/node": "*"
  }
}
